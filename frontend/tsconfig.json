{
    "compilerOptions": {
        "outDir": "./dist/",
        "sourceMap": true,
        "strict": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "target": "es6",
        "allowJs": true,
        "types": ["vitest/globals", "chrome"],
        "lib": ["ES2020", "DOM", "DOM.Iterable"]
    },
    "include": ["./src/"]
}
